config BOARD
    default "lilygo-t-display-gd32" if BOARD_LILYGO_T_DISPLAY_GD32

config BOARD_LILYGO_T_DISPLAY_GD32
    bool
    default y
    select CPU_MODEL_GD32VF103C8T6
    select BOARD_HAS_HXTAL
    select BOARD_HAS_LXTAL
    select HAS_PERIPH_ADC
    select HAS_PERIPH_DAC
    select HAS_PERIPH_I2C
    select HAS_PERIPH_PWM
    select HAS_PERIPH_SPI
    select HAS_PERIPH_TIMER
    select HAS_PERIPH_UART
    select HAS_PERIPH_USBDEV
    select HAS_RIOTBOOT
    select HAS_TINYUSB_DEVICE
    select HAVE_SAUL_GPIO
    select HAVE_ST7789

    select HAVE_MTD_SDCARD_DEFAULT
    select MODULE_FATFS_VFS if MODULE_VFS_DEFAULT

source "$(RIOTBOARD)/common/gd32v/Kconfig"
